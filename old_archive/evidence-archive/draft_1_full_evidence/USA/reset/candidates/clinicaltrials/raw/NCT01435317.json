    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Improvement of TBF-12 Score or CGI Score",
          "description": "Change of tinnitus severity, measured by TBF-12 Score or CGI score change from baseline to end of treatment.",
          "timeFrame": "12 months"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "NRS loudness and annoyance (0-100)",
          "timeFrame": "0.5, 1, 2, 3, 6, 9, 12 months"
        },
        {
          "measure": "Tinnitus-freedom",
          "timeFrame": "3,6,9,12 months"
        },
        {
          "measure": "Compliance",
          "description": "Questioning if the specified application was kept.",
          "timeFrame": "0.5,1,3,6,9,12 months"
        },
        {
          "measure": "Alteration of tinnitus",
          "description": "Early alteration of tinnitus frequency and psychometric tinnitus loudness, measured with the ANM T30 CR®-System.",
          "timeFrame": "0.5,1,2,3,6,9,12 months"
        },
        {
          "measure": "Audiogram for hearing loss change",
          "timeFrame": "3,12 months"
        },
        {
          "measure": "TBF-12",
          "timeFrame": "3,6,9,12 months"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Main Inclusion Criteria:\n\n* symptomatic subjective tonal chronical (\\> 3 months) tinnitus\n* \\<60dB hearing loss\n* men and women ≥18 years old\n\nMain Exclusion Criteria:\n\n* serious neurologic\n* psychiatric or internistic disease\n* objective tinnitus\n* Morbus Menière\n* craniomandibular triggered tinnitus",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "18 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ]
