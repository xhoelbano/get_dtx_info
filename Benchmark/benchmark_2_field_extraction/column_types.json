{
  "_comment": "Schema-driven metric configuration for Benchmark 2 (field-level extraction quality). Each column declares the metric used to score the model's value against the ground truth, following the per-field 'evaluation_config' pattern of structured-extraction benchmarks (ExtractBench, ContextualAI/extract-bench). The two linkage fields (trial_registration_id, sources_publications) are used only to match studies and are skipped in scoring. See methodology.md for formulas and references.",
  "linkage_fields": ["trial_registration_id", "sources_publications"],
  "company_level_fields": [
    "dtx_name", "is_it_a_diga", "company_provider", "company_founding_year",
    "diga_listing_status", "diga_listing_date", "category", "risk_class",
    "clinical_area_icd10", "rating_on_playstore", "reviews_on_playstore",
    "rating_on_appstore", "reviews_on_appstore"
  ],
  "study_level_fields": [
    "evidence_type", "primary_end_point_duration_weeks",
    "follow_up_after_primary_end_point", "duration_additional_info",
    "study_size_participants", "intervention_and_control_group", "trial_arms",
    "additional_info_about_trial_arms", "collected_data", "key_outcomes_findings",
    "trial_start_date", "trial_end_date", "publication_date"
  ],
  "columns": {
    "dtx_name":                          { "group": "name",        "metric": "name_norm_fuzzy" },
    "is_it_a_diga":                      { "group": "categorical", "metric": "exact_norm" },
    "company_provider":                  { "group": "name",        "metric": "name_norm_fuzzy" },
    "company_founding_year":             { "group": "numeric",     "metric": "int_exact" },
    "diga_listing_status":               { "group": "categorical", "metric": "exact_norm" },
    "diga_listing_date":                 { "group": "date",        "metric": "iso_date" },
    "category":                          { "group": "categorical", "metric": "concept_set" },
    "risk_class":                        { "group": "categorical", "metric": "risk_class_norm" },
    "clinical_area_icd10":               { "group": "set",         "metric": "icd10_set" },
    "rating_on_playstore":               { "group": "numeric",     "metric": "float_tolerance", "tolerance": 0.05 },
    "reviews_on_playstore":              { "group": "numeric",     "metric": "int_exact" },
    "rating_on_appstore":                { "group": "numeric",     "metric": "float_tolerance", "tolerance": 0.05 },
    "reviews_on_appstore":               { "group": "numeric",     "metric": "int_exact" },
    "evidence_type":                     { "group": "categorical", "metric": "exact_norm" },
    "primary_end_point_duration_weeks":  { "group": "numeric",     "metric": "int_exact" },
    "follow_up_after_primary_end_point": { "group": "short_mixed", "metric": "short_norm_tokenf1" },
    "duration_additional_info":          { "group": "free_text",   "metric": "bertscore_tokenf1" },
    "study_size_participants":           { "group": "numeric",     "metric": "int_exact" },
    "intervention_and_control_group":    { "group": "free_text",   "metric": "bertscore_tokenf1" },
    "trial_arms":                        { "group": "numeric",     "metric": "int_exact" },
    "additional_info_about_trial_arms":  { "group": "free_text",   "metric": "bertscore_tokenf1" },
    "collected_data":                    { "group": "free_text",   "metric": "bertscore_tokenf1" },
    "key_outcomes_findings":             { "group": "free_text",   "metric": "bertscore_tokenf1" },
    "trial_registration_id":             { "group": "linkage",     "metric": "skip" },
    "trial_start_date":                  { "group": "date",        "metric": "iso_date" },
    "trial_end_date":                    { "group": "date",        "metric": "iso_date" },
    "publication_date":                  { "group": "date",        "metric": "iso_date" },
    "sources_publications":              { "group": "linkage",     "metric": "skip" }
  },
  "category_synonyms": {
    "_comment": "Maps observed category surface forms (lowercased) to a canonical clinical concept. GT and model values are split on ; / , then each token is mapped; scoring uses set overlap of canonical concepts. Unmapped tokens fall back to themselves, so they only match identical tokens. This is an explicit, editable heuristic (see methodology.md limitation).",
    "psyche": "mental_health",
    "mental health": "mental_health",
    "mental disorders": "mental_health",
    "psyche / mental disorders/ insomnia": "mental_health",
    "sleep": "sleep",
    "sleep disorders": "sleep",
    "sleep medicine / chronic insomnia": "sleep",
    "insomnia": "sleep",
    "muscles, bones and joints": "musculoskeletal",
    "musculoskeletal": "musculoskeletal",
    "musculoskeletal system": "musculoskeletal",
    "msk": "musculoskeletal",
    "chronic pain": "chronic_pain",
    "digestion": "digestion",
    "cancer": "oncology",
    "oncology": "oncology",
    "ophthalmology": "ophthalmology",
    "ophthalmic / sensory organs especially for amblyopia": "ophthalmology",
    "amblyopia": "ophthalmology",
    "nervous system": "nervous_system",
    "women's health / pelvic health": "womens_health",
    "heart and circulation": "cardiovascular",
    "hormones and metabolism": "endocrine_metabolism",
    "menopause / vasomotor symptoms / thermal comfort therapy": "menopause",
    "injuries": "injuries",
    "stroke rehabilitation": "stroke_rehab"
  }
}
