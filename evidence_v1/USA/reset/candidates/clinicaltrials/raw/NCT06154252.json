          "measure": "To evaluate autoantibody -related biomarkers",
          "description": "Levels of autoantibodies from the Myositis-Specific Autoantibody Panel (e.g., MDA-5, Jo-1, and HMGCR) in the serum",
          "timeFrame": "Up to 156 weeks"
        },
