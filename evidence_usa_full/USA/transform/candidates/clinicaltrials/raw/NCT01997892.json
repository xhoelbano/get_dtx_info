    "descriptionModule": {
      "briefSummary": "To describe the time course of hemoglobin concentration in EU hemodialysis patients switched from methoxy polyethylene glycol-epoetin beta (PEG epoetin beta; Mircera) to darbepoetin alfa (Aranesp).",
      "detailedDescription": "This is a multi-centre, observational cohort study of EU hemodialysis patients whose erythropoiesis stimulating agent (ESA) therapy has been switched from PEG epoetin beta to darbepoetin alfa. Data will be collected for the period spanning 14 weeks prior to switch through to 26 weeks post-switch."
    },
    "conditionsModule": {
      "conditions": [
        "Anemia"
      ],
