# Copy this file to .env and fill in the values for the provider(s) you use.
#   cp .env.example .env

# === LLM Provider Selection ===
# Which provider the pipeline uses by default.
# Options: azure_openai, openai, gemini, anthropic
LLM_PROVIDER=openai

# Enable the provider's native web search (used by the general/non-German path
# to research companies/DTx). Supported on openai/gemini/anthropic; NOT on
# azure_openai (Chat Completions has no web-search tool).
ENABLE_WEB_SEARCH=true

# === Phase 2: Website evidence search (browser-use) ===
# When true, find-evidence runs the browser-use website agent for every DTx
# that has a company_website. When false, it never runs.
ENABLE_WEBSITE_SEARCH=false

# Optional: which provider/model the browser-use website agent uses.
# Defaults to LLM_PROVIDER (and that provider's model) when unset.
# BROWSER_USE_PROVIDER=gemini
# BROWSER_USE_MODEL=gemini-3.1-pro-preview

# === Phase 3: Evidence analysis (analyze-evidence) ===
# Optional: which provider/model the Phase 3 analyzer uses. Defaults to
# LLM_PROVIDER when unset. Outputs are namespaced per model so different
# models never overwrite each other.
# PHASE3_PROVIDER=openai
# PHASE3_MODEL=gpt-4o

# === Azure OpenAI ===
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# === OpenAI ===
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o

# === Google Gemini ===
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-3.1-pro-preview

# === Anthropic Claude ===
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Other (optional) ===
HUGGINGFACEHUB_API_TOKEN=your-huggingface-token
